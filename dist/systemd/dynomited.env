# Default environment for the dynomited(8) systemd unit.
#
# Either /etc/sysconfig/dynomited (rpm) or /etc/default/dynomited
# (deb) is loaded by the unit; only one of the two should exist
# on a given host. Override either of these variables to point
# at a non-default config or pid file.

DYNOMITED_CONF=/etc/dynomite/dynomite.yml
DYNOMITED_PIDFILE=/var/run/dynomite/dynomited.pid
